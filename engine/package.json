{
  "name": "pred-scout-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Kit-math build engine for Predecessor Scout (v5 design, docs/v5-engine-design.md)",
  "scripts": {
    "answer": "tsx src/cli.ts",
    "probe": "tsx src/ingest/probe.ts",
    "drift": "tsx src/ingest/drift.ts",
    "aggregate": "tsx src/ingest/aggregate.ts",
    "artifacts": "tsx src/ingest/build-artifacts.ts",
    "coach": "tsx src/ingest/coach.ts",
    "squad": "tsx src/ingest/squad.ts",
    "buildstats": "tsx src/ingest/buildstats.ts",
    "snapshot": "tsx src/ingest/snapshot.ts",
    "refresh": "npm run snapshot && npm run augments && npm run buildstats && npm run skills && npm run aggregate && npm run artifacts && npm run matrix && npm run agreement",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "calibrate": "tsx src/ingest/calibrate-from-data.ts",
    "matrix": "tsx src/ingest/matchup-matrix.ts",
    "matchups": "tsx src/ingest/matchup-evidence.ts",
    "ranksplit": "tsx src/ingest/rank-split.ts",
    "augments": "tsx src/ingest/augments.ts",
    "review": "tsx src/ingest/augment-review.ts",
    "review:items": "tsx src/ingest/item-review.ts",
    "review:abilities": "tsx src/ingest/ability-review.ts",
    "review:builds": "tsx src/ingest/build-review.ts",
    "review:coach": "tsx src/ingest/coach-review.ts",
    "review:critique": "tsx src/ingest/copy-critique.ts",
    "review:critique:prepare": "COPY_MODE=prepare tsx src/ingest/copy-critique.ts",
    "review:loop:gate": "tsx src/ingest/loop-gate.ts",
    "ui:audit": "tsx src/ingest/ui-audit.ts",
    "ui:render": "PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers tsx src/ingest/ui-render.ts",
    "ui:audit:v0": "UI_DIR=ui/v0 tsx src/ingest/ui-audit.ts",
    "ui:render:v0": "PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers UI_DIR=ui/v0 tsx src/ingest/ui-render.ts",
    "ux:critique:prepare": "COPY_MODE=prepare tsx src/ingest/ux-critique.ts",
    "ux:critique": "tsx src/ingest/ux-critique.ts",
    "ux:loop:gate": "LOOP_HISTORY=data/aggregates/ux-v0-history.json tsx src/ingest/loop-gate.ts",
    "copy:prepare": "COPY_MODE=prepare tsx src/ingest/augment-review.ts && COPY_MODE=prepare tsx src/ingest/item-review.ts && COPY_MODE=prepare tsx src/ingest/ability-review.ts && COPY_MODE=prepare tsx src/ingest/build-review.ts && COPY_MODE=prepare tsx src/ingest/coach-review.ts",
    "copy:ingest": "tsx src/ingest/augment-review.ts && tsx src/ingest/item-review.ts && tsx src/ingest/ability-review.ts && tsx src/ingest/build-review.ts && tsx src/ingest/coach-review.ts",
    "skills": "tsx src/ingest/skill-orders.ts",
    "classify": "tsx src/ingest/classify.ts",
    "objectives": "tsx src/ingest/objectives.ts",
    "postgame": "tsx src/ingest/postgame.ts",
    "postgame:kit": "tsx src/ingest/postgame-kit.ts",
    "postgame:macro": "tsx src/ingest/postgame-macro.ts",
    "item-model": "tsx src/ingest/item-model-doc.ts",
    "explain": "tsx src/ingest/explain-build.ts",
    "agreement": "tsx src/ingest/agreement-audit.ts",
    "flex-preview": "tsx src/ingest/flex-preview.ts",
    "map:calibrate": "tsx src/ingest/map-calibrate.ts",
    "coach:critique:prepare": "COPY_MODE=prepare tsx src/ingest/coach-critique.ts",
    "coach:critique": "tsx src/ingest/coach-critique.ts",
    "coach:loop:gate": "LOOP_HISTORY=data/aggregates/coach-critique-history.json tsx src/ingest/loop-gate.ts",
    "postgame:items": "tsx src/ingest/postgame-items.ts",
    "postgame:fights": "tsx src/ingest/postgame-fights.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "playwright": "^1.60.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  }
}
